{
  "name": "lan-transfer-panel",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "中文局域网文件传输面板，代理 rclone RC 和 aria2 RPC。",
  "scripts": {
    "start": "node server.js",
    "dev": "node scripts/dev-all.js",
    "dev:server": "node scripts/dev-server.js",
    "build": "npm --prefix desktop run build",
    "test": "node --test \"test/*.test.js\"",
    "desktop:dev": "npm --prefix desktop run tauri:dev",
    "desktop:build": "npm --prefix desktop run tauri:build",
    "desktop:test": "npm --prefix desktop test"
  },
  "engines": {
    "node": ">=20"
  }
}
